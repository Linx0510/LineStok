<%- include('../partials/header') %>

<div class="admin-container">
    <div class="admin-sidebar">
        <div class="admin-nav">
            <a href="/admin" class="admin-nav-link <%= path === '/admin' ? 'active' : '' %>">
                <i class="fas fa-dashboard"></i> Дашборд
            </a>
            <a href="/admin/moderation" class="admin-nav-link <%= path === '/admin/moderation' ? 'active' : '' %>">
                <i class="fas fa-check-circle"></i> Модерация
                <% if (stats.works.pending > 0) { %>
                    <span class="badge"><%= stats.works.pending %></span>
                <% } %>
            </a>
            <a href="/admin/complaints" class="admin-nav-link <%= path === '/admin/complaints' ? 'active' : '' %>">
                <i class="fas fa-flag"></i> Жалобы
                <% if (stats.openComplaints > 0) { %>
                    <span class="badge"><%= stats.openComplaints %></span>
                <% } %>
            </a>
            <a href="/admin/users" class="admin-nav-link <%= path === '/admin/users' ? 'active' : '' %>">
                <i class="fas fa-users"></i> Пользователи
            </a>
            <a href="/admin/settings" class="admin-nav-link <%= path === '/admin/settings' ? 'active' : '' %>">
                <i class="fas fa-cog"></i> Настройки
            </a>
        </div>
    </div>
    
    <div class="admin-content">
        <h1>Панель управления</h1>
        
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.users %></h3>
                    <p>Всего пользователей</p>
                    <small>+<%= stats.newUsersToday %> сегодня</small>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-image"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.works.approved %></h3>
                    <p>Опубликовано работ</p>
                    <small>+<%= stats.worksToday %> сегодня</small>
                </div>
            </div>
            
            <div class="stat-card warning">
                <div class="stat-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.works.pending %></h3>
                    <p>Ожидают модерации</p>
                </div>
            </div>
            
            <div class="stat-card danger">
                <div class="stat-icon">
                    <i class="fas fa-flag"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.openComplaints %></h3>
                    <p>Открытых жалоб</p>
                </div>
            </div>
        </div>
        
        <div class="admin-grid">
            <div class="admin-card">
                <h2>Последние пользователи</h2>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Имя</th>
                            <th>Email</th>
                            <th>Роль</th>
                            <th>Дата регистрации</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentUsers.forEach(user => { %>
                            <tr>
                                <td>#<%= user.id %></td>
                                <td><%= user.username %></td>
                                <td><%= user.email %></td>
                                <td>
                                    <span class="badge <%= user.role === 'admin' ? 'badge-primary' : 'badge-secondary' %>">
                                        <%= user.role === 'admin' ? 'Админ' : 'Пользователь' %>
                                    </span>
                                </td>
                                <td><%= new Date(user.created_at).toLocaleDateString('ru-RU') %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
                <a href="/admin/users" class="btn btn-outline btn-sm">Все пользователи</a>
            </div>
            
            <div class="admin-card">
                <h2>Популярные теги</h2>
                <div class="tags-cloud">
                    <% popularTags.forEach(tag => { %>
                        <span class="tag" >
                            #<%= tag.name %> (<%= tag.count %>)
                        </span>
                    <% }) %>
                </div>
            </div>
            
            <div class="admin-card full-width">
                <h2>Активность за последние 7 дней</h2>
                <div class="activity-chart">
                    <% activity.forEach(day => { %>
                        <div class="chart-bar">
                            <div class="bar" ></div>
                            <span class="bar-label"><%= new Date(day.date).toLocaleDateString('ru-RU', { weekday: 'short' }) %></span>
                            <span class="bar-value"><%= day.count %></span>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>


<%- include('../partials/footer') %>