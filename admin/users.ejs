<%- include('../partials/header') %>

<div class="admin-container">
    <div class="admin-sidebar">
        <div class="admin-nav">
            <a href="/admin" class="admin-nav-link">Дашборд</a>
            <a href="/admin/moderation" class="admin-nav-link">Модерация</a>
            <a href="/admin/complaints" class="admin-nav-link">Жалобы</a>
            <a href="/admin/users" class="admin-nav-link active">Пользователи</a>
            <a href="/admin/settings" class="admin-nav-link">Настройки</a>
        </div>
    </div>

    <div class="admin-content">
        <div class="content-header users-header">
            <h1>Управление пользователями</h1>
            <form class="search-form" method="GET" action="/admin/users">
                <input
                    type="text"
                    name="search"
                    value="<%= search %>"
                    placeholder="Поиск по имени или email"
                >
                <button type="submit" class="btn btn-primary btn-sm">Найти</button>
                <% if (search) { %>
                    <a href="/admin/users" class="btn btn-outline btn-sm">Сброс</a>
                <% } %>
            </form>
        </div>

        <% if (users.length > 0) { %>
            <div class="users-table-wrap">
                <table class="users-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Пользователь</th>
                            <th>Email</th>
                            <th>Роль</th>
                            <th>Работ</th>
                            <th>Дата регистрации</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(item => { %>
                            <tr data-user-id="<%= item.id %>">
                                <td>#<%= item.id %></td>
                                <td><%= item.username %></td>
                                <td><%= item.email %></td>
                                <td>
                                    <select class="role-select" onchange="updateRole(`<%= item.id %>, this.value`)">
                                        <option value="user" <%= item.role === 'user' ? 'selected' : '' %>>Пользователь</option>
                                        <option value="admin" <%= item.role === 'admin' ? 'selected' : '' %>>Админ</option>
                                    </select>
                                </td>
                                <td><%= item.works_count %></td>
                                <td><%= new Date(item.created_at).toLocaleDateString('ru-RU') %></td>
                                <td>
                                    <% if (!user || user.id !== item.id) { %>
                                        <button class="btn btn-danger btn-sm" onclick="deleteUser(`<%= item.id %>`)">
                                            Удалить
                                        </button>
                                    <% } else { %>
                                        <span class="muted">Текущий аккаунт</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <% if (totalPages > 1) { %>
                <div class="pagination">
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="/admin/users?page=<%= i %><%= search ? `&search=${encodeURIComponent(search)}` : '' %>"
                           class="page <%= currentPage === i ? 'active' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>
                </div>
            <% } %>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-users"></i>
                <h3>Пользователи не найдены</h3>
                <p>Попробуйте изменить поисковый запрос.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
async function updateRole(userId, role) {
    try {
        const response = await fetch(`/admin/users/${userId}/role`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ role })
        });

        const data = await response.json();

        if (!data.success) {
            alert(data.message || 'Не удалось изменить роль');
            window.location.reload();
        }
    } catch (error) {
        console.error(error);
        alert('Ошибка при изменении роли');
        window.location.reload();
    }
}

async function deleteUser(userId) {
    if (!confirm('Удалить пользователя? Это действие нельзя отменить.')) return;

    try {
        const response = await fetch(`/admin/users/${userId}`, {
            method: 'DELETE',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });

        const data = await response.json();

        if (data.success) {
            document.querySelector(`tr[data-user-id="${userId}"]`)?.remove();
            return;
        }

        alert(data.message || 'Не удалось удалить пользователя');
    } catch (error) {
        console.error(error);
        alert('Ошибка при удалении пользователя');
    }
}
</script>